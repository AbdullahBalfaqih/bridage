
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model combined with structural segregation for public data.
 * The core principle is "Authorization Independence," where authorization data (like owner IDs) is denormalized
 * directly onto documents to create fast, simple, and secure rules without needing expensive cross-document lookups.
 *
 * Data Structure:
 * - /users/{userId}: Private user-specific data, including their profile, private projects, and investment history.
 *   Access is strictly limited to the authenticated user who owns that data tree.
 * - /public_projects/{projectId}: A separate top-level collection for projects that are approved and visible to all
 *   authenticated users. This structural segregation ensures that public queries (`list` operations) are secure by design.
 * - /roles_admin/{userId}: An admin-only collection where the existence of a document grants a user administrative privileges.
 *
 * Key Security Decisions:
 * - Default Deny: All paths are closed by default. Access is granted explicitly.
 * - User Scoping: All data in the `/users/{userId}` tree is strictly private and accessible only to the owner.
 * - Public vs. Private Data: Private project drafts live in a user's subcollection (`/users/{uid}/projects`), while
 *   approved, viewable projects are in a separate public collection (`/public_projects`). This prevents accidental data leakage.
 * - Admin Roles: Administrative privileges are granted based on the existence of a document in the `/roles_admin` collection.
 *   This is a highly performant pattern for checking roles. Client-side modification of admin roles is disabled for security.
 * - No User Listing: It is not possible for any user, including admins, to list all documents in the `/users` collection.
 * - Write Integrity: All write operations validate that the user is who they say they are and that essential relational
 *   identifiers (like `submitterId` or `investorId`) are set correctly on creation and are immutable on update.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     * @param userId The user ID to check against the authenticated user.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Returns true if the document being accessed already exists in Firestore.
     * CRITICAL for all update and delete operations to prevent unintended side effects.
     */
    function documentExists() {
      return resource != null;
    }

    /**
     * A secure convenience function that combines an ownership check with an
     * existence check. Used for all state-changing operations on existing documents.
     * @param userId The user ID to check for ownership.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && documentExists();
    }

    /**
     * Checks if the user has an admin role by verifying the existence of a
     * document in the roles_admin collection corresponding to their UID.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * VALIDATION (CREATE): Ensures the new document's internal `id` field
     * matches the user ID from the path, enforcing data integrity.
     */
    function hasValidUserId(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * VALIDATION (UPDATE): Ensures the document's internal `id` field
     * is immutable and cannot be changed after creation.
     */
    function isUserIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * VALIDATION (CREATE): Ensures a new project's `submitterId` field
     * matches the owner's user ID from the path.
     */
    function hasValidSubmitterId(submitterId) {
      return request.resource.data.submitterId == submitterId;
    }

    /**
     * VALIDATION (UPDATE): Ensures a project's `submitterId` is immutable.
     */
    function isSubmitterIdImmutable() {
      return request.resource.data.submitterId == resource.data.submitterId;
    }

    /**
     * VALIDATION (CREATE): Ensures a new investment's `investorId` field
     * matches the owner's user ID from the path.
     */
    function hasValidInvestorId(investorId) {
      return request.resource.data.investorId == investorId;
    }

    /**
     * VALIDATION (UPDATE): Ensures an investment's `investorId` is immutable.
     */
    function isInvestorIdImmutable() {
      // Fix: 'investorId' was an invalid variable name. It should refer to the existing document's field.
      return request.resource.data.investorId == resource.data.investorId;
    }

    /**
     * VALIDATION (CREATE): Ensures a user creating a public project correctly
     * assigns themselves as the submitter.
     */
    function isCreatingOwnPublicProject() {
      return isSignedIn() && request.resource.data.submitterId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own user profile document.
     * @deny (get) A user cannot read another user's profile document.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && hasValidUserId(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Controls access to a user's private collection of project drafts.
       * @path /users/{userId}/projects/{projectId}
       * @allow (create) The user `user_abc` can create a project in their own `/users/user_abc/projects` collection.
       * @deny (list) The user `user_xyz` cannot list projects from `/users/user_abc/projects`.
       * @principle Enforces strict ownership of all documents within a user's private data subcollections.
       */
      match /projects/{projectId} {
        // Fix: 'submitterId' was an invalid variable name in this path context. It should be 'userId'.
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidSubmitterId(userId);
        allow update: if isExistingOwner(userId) && isSubmitterIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to a user's private investment records.
       * @path /users/{userId}/investments/{investmentId}
       * @allow (get) The user `user_abc` can read an investment from their own `/users/user_abc/investments` collection.
       * @deny (get) The user `user_xyz` cannot read an investment from `/users/user_abc/investments`.
       * @principle Ensures financial transaction history is private and accessible only to the individual investor.
       */
      match /investments/{investmentId} {
        // Fix: 'investorId' was an invalid variable name in this path context. It should be 'userId'.
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidInvestorId(userId);
        allow update: if isExistingOwner(userId) && isInvestorIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      /**
       * @description Controls access to a user's notifications.
       * @path /users/{userId}/notifications/{notificationId}
       * @allow (get, list) The user can read their own notifications.
       * @allow (create) The user can create notifications for themselves.
       * @principle Ensures notifications are private.
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
      
      /**
       * @description Controls access to a user's favorite projects.
       * @path /users/{userId}/favorites/{projectId}
       * @allow (read, list, create, delete) The user can manage their own favorites.
       * @principle Ensures favorites are private and user-managed.
       */
      match /favorites/{projectId} {
        allow get, list, create, delete: if isOwner(userId);
        allow update: if false; // Favorites are either present or not, no updates needed.
      }
    }

    /**
     * @description Controls access to projects that are public and open for funding.
     * @path /public_projects/{projectId}
     * @allow (read) Any user, including unauthenticated ones, can read public projects.
     * @deny (update) A user who is not the original submitter or an admin cannot update a project.
     * @principle Implements "Public Read with Owner-Only Writes" pattern, with an exception for admin overrides.
     */
    match /public_projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if (isOwner(resource.data.submitterId) || isAdmin()) && documentExists() && isSubmitterIdImmutable();
      allow delete: if (isOwner(resource.data.submitterId) || isAdmin()) && documentExists();
    }

    /**
     * @description Controls access to the admin role collection.
     * @path /roles_admin/{userId}
     * @allow (get) An admin can check if another user is also an admin.
     * @deny (create, update, delete) No user can modify admin roles from the client-side.
     * @principle Secures role management by disabling client-side writes. Roles must be managed via the Firebase Console or a trusted server-side process.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}

    